  "keyFeatures": [
    "Native VS Code REST API client with zero startup time",
    "Complete privacy with local-only storage and no telemetry",
    "Collections and environments for organized API management",
    "OAuth 2.0 with Authorization Code, PKCE, and Client Credentials",
    "Pre-request and post-response scripting with Postman-compatible API",
    "Workspace-scoped storage for team collaboration via Git",
    "Built-in cookie jar with automatic domain-based management",
    "Variable substitution with layered resolution (globals, collection, environment)"
  ],
